{
    "$schema": "https://schema.tauri.app/config/2.0.0",
    "productName": "Latiao",
    "version": "0.1.1",
    "identifier": "com.latiao.desktop",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "fullscreen": false,
                "resizable": true,
                "title": "\u8fa3\u6761 Latiao",
                "width": 1200,
                "height": 800,
                "useHttpsScheme": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8000 https://huggingface.co https://api.deepseek.com https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com; img-src 'self' data: blob:; media-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob: https://github.com"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": {
            "../sidecar": "sidecar"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "shell": {
            "allow": [
                {
                    "name": "sidecar/*"
                }
            ]
        },
        "updater": {
            "active": true,
            "endpoints": [
                "https://github.com/RenYiX0620/Latiao/releases/latest/download/latest.json"
            ],
            "dialog": true,
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzOTc1NDgyMEFGMkM3RUQKUldUdHgvSUtnbFNYWTJzaDQ5ZEJZOGVNMGFBZGpSazhlY3JFaEhoc1FCWTh4d0ZkSUVocmVId0YK"
        }
    }
}
{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Latiao",
  "version": "0.1.0",
  "identifier": "com.latiao.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "辣条 Latiao",
        "width": 1200,
        "height": 800,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8000 https://huggingface.co https://api.deepseek.com https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com; img-src 'self' data: blob:; media-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "allow": [
        {
          "name": "sidecar/*"
        }
      ]
    }
  }
}
